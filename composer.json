{
    "name": "dashed/dashed-omnisocials",
    "description": "Omnisocials publishing adapter for Dashed Marketing",
    "keywords": ["Dashed", "laravel", "dashed-omnisocials", "social-media"],
    "homepage": "https://github.com/Dashed-DEV/dashed-omnisocials",
    "license": "MIT",
    "authors": [
        {
            "name": "Robin van Maasakker",
            "email": "robin@dashed.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "dashed/dashed-core": "*",
        "dashed/dashed-marketing": "*",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Dashed\\DashedOmnisocials\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dashed\\DashedOmnisocials\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dashed\\DashedOmnisocials\\DashedOmnisocialsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
